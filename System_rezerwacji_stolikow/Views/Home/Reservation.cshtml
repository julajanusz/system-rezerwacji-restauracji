<h1>Zarezerwuj stolik w Dolce Vita już dziś!</h1>

<form asp-controller="Home" asp-action="Reservation" method="post">
    <div class="mb-4">
        <label class="form-label">Imię i nazwisko</label>
        <input type="text" name="Name" class="form-control" required/>
    </div>

    <div class="mb-4">
        <label class="form-label">Numer telefonu</label>
        <input 
            type="tel" name="Phone" class="form-control"
               pattern="[0-9]{9}" required />
    </div>

    <div class="mb-4">
        <label class="form-label">Data rezerwacji</label>
        <input 
            type="date" name="ReservationDate" class="form-control"
               min="@DateTime.Now.ToString("yyyy-MM-dd")" required />
    </div>

    <div class="mb-4">
        <label class="form-label">Godzina rezerwacji</label>
        <input 
            type="time" name="ReservationTime" class="form-control"
               min="13:00" max="21:00" step="900" required />
    </div>

    <div class="mb-4">
        <label class="form-label">Liczba osób</label>
        <input 
            type="number" name="PeopleCount" class="form-control"
               min="1" max="10" required />
    </div>


    <button type="submit" class="btn btn-primary">
        Zarezerwuj!
    </button>
</form>
