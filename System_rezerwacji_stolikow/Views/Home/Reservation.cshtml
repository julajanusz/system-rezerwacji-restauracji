<h1>Zarezerwuj stolik w Dolce Vita już dziś!</h1>

<form>
    <div class="mb-4">
        <label class="form-label">Imię i nazwisko</label>
        <input type="text" class="form-control" required/>
    </div>

    <div class="mb-4">
        <label class="form-label">Numer telefonu</label>
        <input 
            type="tel" class="form-control"
               pattern="[0-9]{9}" required />
    </div>

    <div class="mb-4">
        <label class="form-label">Data rezerwacji</label>
        <input 
            type="date" class="form-control"
               min="@DateTime.Now.ToString("yyyy-MM-dd")" required />
    </div>

    <div class="mb-4">
        <label class="form-label">Godzina rezerwacji</label>
        <input 
            type="time" class="form-control"
               min="13:00" max="21:00" step="900" required />
    </div>

    <div class="mb-4">
        <label class="form-label">Liczba osób</label>
        <input 
            type="number" class="form-control"
               min="1" max="10" required />
    </div>


    <button type="submit" class="btn btn-primary">
        Zarezerwuj!
    </button>
</form>
